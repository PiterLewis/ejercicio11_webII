{
  "name": "ejercicio11-biblioteca-deploy",
  "version": "1.0.0",
  "description": "API REST de Biblioteca Digital — Deploy & DevOps (Docker + CI/CD)",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node src/index.js",
    "start:env": "node --env-file=.env src/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "docker:build": "docker build -t biblioteca-api .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env biblioteca-api",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f"
  },
  "keywords": [
    "biblioteca",
    "prisma",
    "postgres",
    "express",
    "jwt",
    "docker",
    "ci-cd",
    "devops"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prisma": "^6.2.1",
    "supertest": "^6.3.3"
  }
}
