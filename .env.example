NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Supabase da dos cadenas (Settings, apartado Database).
# La de puerto 5432 es conexión directa, va en DATABASE_URL.
# La de puerto 6543 es el pooler (Supavisor), va en DIRECT_URL.
# En Postgres local sin pooler, ambas apuntan a la misma URL.
DATABASE_URL=postgresql://user:password@host:5432/db?schema=public
DIRECT_URL=postgresql://user:password@host:5432/db

# Mínimo 32 caracteres.
# Generar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres_random
JWT_EXPIRES_IN=2h

# En producción lista separada por comas (p. ej. https://app.ejemplo.com,https://admin.ejemplo.com)
CORS_ORIGIN=*
