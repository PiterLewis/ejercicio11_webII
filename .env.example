NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Supabase expone dos cadenas (Project Settings, Database, Connection string):
# - Transaction pooler (puerto 6543): conexiones cortas de la app en runtime.
#   PgBouncer en modo transacción NO soporta prepared statements, así que hay
#   que añadir ?pgbouncer=true para que Prisma use el protocolo simple.
#   Sin ese flag aparece el error 42P05 "prepared statement s0 already exists".
# - Conexión directa / session (puerto 5432): la usa Prisma para migraciones.
DATABASE_URL=postgresql://postgres.REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Mínimo 32 caracteres.
# Generar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres_random
JWT_EXPIRES_IN=2h

# En producción lista separada por comas (p. ej. https://app.ejemplo.com,https://admin.ejemplo.com)
CORS_ORIGIN=*
