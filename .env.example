# ==================== ENTORNO ====================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ==================== BASE DE DATOS ====================
# Local (docker compose):
#   postgresql://biblioteca:biblioteca@localhost:5432/biblioteca?schema=public
# Supabase / Railway / Render: copia la URL de conexión del panel.
DATABASE_URL=postgresql://user:password@host:5432/db?schema=public
DIRECT_URL=postgresql://user:password@host:5432/db

# ==================== JWT ====================
# Mínimo 32 caracteres. En producción genera un valor aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres_random
JWT_EXPIRES_IN=2h

# ==================== CORS ====================
# "*" en dev. En prod, lista separada por comas:
# https://app.ejemplo.com,https://admin.ejemplo.com
CORS_ORIGIN=*
